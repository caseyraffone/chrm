{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://chrm-two.vercel.app",
        "REVENUECAT_API_KEY_IOS": "${REVENUECAT_API_KEY_IOS}"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE_URL": "https://chrm-two.vercel.app",
        "REVENUECAT_API_KEY_IOS": "${REVENUECAT_API_KEY_IOS}"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {}
    },
    "production": {
      "ios": {
        "ascAppId": "6759968325"
      }
    }
  }
}
