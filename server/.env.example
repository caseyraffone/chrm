# Copy to server/.env and fill in. These keys live ONLY on the server.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey... # server only; never expose to the app/web client

# RevenueCat webhook auth. Set the SAME value as the "Authorization header"
# in RevenueCat → Project → Integrations → Webhooks. Events POST to
# /api/revenuecat/webhook and update subscription_entitlements (cross-platform Pro).
REVENUECAT_WEBHOOK_SECRET=

# Stripe web checkout (browser subscriptions). Prices are recurring Price IDs
# from the Stripe dashboard; the webhook secret is from the /api/stripe/webhook
# endpoint you register in Stripe → Developers → Webhooks.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# WEB_APP_URL=https://your-web-app.com   # fallback for Checkout success/return URLs

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6
# PORT=8787
# ALLOWED_ORIGIN=https://your-web-app.com   # lock CORS down in production
