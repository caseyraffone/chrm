# CHRM backend env vars — set these in the Vercel project settings, NOT in the
# client app. These keys must never ship in a client bundle.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of allowed origins for CORS (the web app + local dev).
# Use "*" only for early testing. Native (Expo) requests have no Origin and are
# always allowed.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Phase 1e (rate limiting) — Upstash Redis REST credentials. Left blank for now;
# until set, the backend uses a best-effort in-memory limiter (per-instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
